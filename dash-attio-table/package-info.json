{
  "name": "dash-attio-table",
  "version": "1.0.0",
  "description": "Modern Handsontable component for Dash with native theming support",
  "main": "index.ts",
  "repository": {
    "type": "git",
    "url": "git://github.com/attio/dash-attio-table.git"
  },
  "bugs": {
    "url": "https://github.com/attio/dash-attio-table/issues"
  },
  "homepage": "https://github.com/attio/dash-attio-table",
  "scripts": {
    "build:js::dev": "webpack --mode development",
    "build:js": "webpack", 
    "build:backends": "dash-generate-components ./src/ts/components dash_attio_table -p package-info.json --r-prefix '' --jl-prefix '' --ignore \\.test\\.",
    "build": "npm run build:js && npm run build:backends",
    "watch": "npm run build:js::dev -- --watch"
  },
  "dependencies": {
    "@handsontable/react": "^16.0.1",
    "handsontable": "^16.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "css-loader": "^6.11.0",
    "npm-run-all": "^4.1.5",
    "ramda": "^0.28.0",
    "react": "^18.2.0",
    "react-docgen": "^6.0.0",
    "react-dom": "^18.2.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.92.0",
    "webpack-cli": "^5.1.0"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
