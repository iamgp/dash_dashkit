{
  "name": "dash-attio",
  "version": "1.0.0",
  "description": "TailwindCSS build for Dash Attio components",
  "scripts": {
    "build-css": "tailwindcss -i ./src/assets/input.css -o ./src/assets/style.css --watch",
    "build-css-prod": "tailwindcss -i ./src/assets/input.css -o ./src/assets/style.css --minify"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0",
    "@tailwindcss/forms": "^0.5.7"
  }
}